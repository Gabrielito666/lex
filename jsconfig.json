{
  "compilerOptions":
  {
    "checkJs": true,
    "allowJs": true,
	"esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
	"types": ["node"],
	"allowSyntheticDefaultImports": true,
	"target": "ES2022",
    "baseUrl": ".",
    "skipLibCheck": true,
    "strict": true,
    "paths" : {
	    "#lib/*": ["./lib/*/index.js"],
	    "#build-lib/*": ["./build-lib/*/index.js"]
    }
  },
  "include": ["**/*.js", "**/*.d.ts"]
}
